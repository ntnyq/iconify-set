{
  "name": "iconify-set",
  "type": "module",
  "version": "0.1.5",
  "packageManager": "pnpm@10.33.0",
  "description": "Check if given string is an iconify icon set name",
  "keywords": [
    "check",
    "iconify",
    "iconify-collection",
    "iconify-set",
    "iconify-set-name",
    "validate"
  ],
  "license": "MIT",
  "author": {
    "name": "ntnyq",
    "email": "ntnyq13@gmail.com"
  },
  "homepage": "https://github.com/ntnyq/iconify-set#readme",
  "repository": "ntnyq/iconify-set",
  "bugs": {
    "url": "https://github.com/ntnyq/iconify-set/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch src",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "iconify:pretty": "oxfmt src/iconify.json",
    "iconify:update": "tsx scripts/update.ts",
    "lint": "eslint",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck test",
    "release:version": "bumpp",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "update": "run-s iconify:update iconify:pretty"
  },
  "devDependencies": {
    "@ntnyq/eslint-config": "^6.0.1",
    "@types/node": "^25.6.0",
    "bumpp": "^11.0.1",
    "consola": "^3.4.2",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "nano-staged": {
    "*.{js,ts,mjs,md,yml,yaml,json}": "eslint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
